{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "declaration": false,
    "outDir": ".ffmpeg-backend-build",
    "rootDir": "src",
    "verbatimModuleSyntax": true
  },
  "include": ["src/ffmpeg/**/*.ts", "src/vite-env.d.ts"]
}
